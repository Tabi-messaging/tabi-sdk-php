{
    "name": "tabi/sdk",
    "description": "Official PHP SDK for the Tabi WhatsApp business messaging API",
    "license": "MIT",
    "type": "library",
    "keywords": ["tabi", "whatsapp", "api", "sdk", "messaging", "business"],
    "homepage": "https://tabi.africa/sdks",
    "support": {
        "docs": "https://tabi.africa/sdks"
    },
    "authors": [
        {
            "name": "Tabi",
            "homepage": "https://tabi.africa"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "Tabi\\SDK\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
